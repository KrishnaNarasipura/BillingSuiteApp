@using BillingSuite.Application.DTOs
@using BillingSuite.Application.Enums
@model BillingSuite.Application.Results.PagedResult<InvoiceDto>
@{
    Layout = "_Layout";
    var currentPage = ViewContext.HttpContext.Request.Query["page"].ToString();
    var currentFrom = ViewContext.HttpContext.Request.Query["from"].ToString();
    var currentTo = ViewContext.HttpContext.Request.Query["to"].ToString();
    var currentCustomerId = ViewContext.HttpContext.Request.Query["CustomerId"].ToString();
    var currentInvoiceNumber = ViewContext.HttpContext.Request.Query["invoiceNumber"].ToString();
    var currentStatus = ViewContext.HttpContext.Request.Query["status"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Invoices</h3>
    <a class="btn btn-primary" href="/Invoices/Create">Create</a>
</div>

<!-- Filters Section -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Filters</h5>
    </div>
    <div class="card-body">
        <form method="get" action="/Invoices" class="row g-3">
            <div class="col-md-2">
                <label for="invoiceNumber" class="form-label">Invoice Number</label>
                <input type="text" class="form-control" id="invoiceNumber" name="invoiceNumber" value="@currentInvoiceNumber" />
            </div>
            <div class="col-md-2">
                <label for="from" class="form-label">From Date</label>
                <input type="date" class="form-control" id="from" name="from" value="@currentFrom" />
            </div>
            <div class="col-md-2">
                <label for="to" class="form-label">To Date</label>
                <input type="date" class="form-control" id="to" name="to" value="@currentTo" />
            </div>
            <div class="col-md-2">
                <label for="status" class="form-label">Status</label>
                <select class="form-select" id="status" name="status">
                    <option value="">All Status</option>
                    <option value="0" selected="@(currentStatus == "0")">Draft</option>
                    <option value="1" selected="@(currentStatus == "1")">Issued</option>
                    <option value="2" selected="@(currentStatus == "2")">Cancelled</option>
                    <option value="3" selected="@(currentStatus == "3")">Paid</option>
                    <option value="4" selected="@(currentStatus == "4")">Partially Paid</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="CustomerId" class="form-label">Customer</label>
                <select class="form-select" id="CustomerId" name="CustomerId">
                    <option value="">All Customers</option>
                    @if (ViewBag.Customers != null)
                    {
                        @foreach (var customer in (IEnumerable<CustomerDto>)ViewBag.Customers)
                        {
                            <option value="@customer.Id" selected="@(currentCustomerId == customer.Id.ToString())">@customer.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                <a href="/Invoices" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Results Summary -->
@if (Model.TotalCount > 0)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
            Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount invoices
        </small>
    </div>
}

<!-- Invoices Table -->
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Invoice #</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Net Amount</th>
            <th>Advance Received</th>
            <th>Order Balance</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var invoice in Model.Items)
            {
                var statusBadgeColor = invoice.Status switch
                {
                    0 => "secondary",  // Draft
                    1 => "info",       // Issued
                    2 => "danger",     // Cancelled
                    3 => "success",    // Paid
                    4 => "warning",    // PartiallyPaid
                    _ => "dark"
                };
                var statusText = ((InvoiceStatus)invoice.Status).ToString();
                var orderBalance = invoice.NetAmount - invoice.AdvanceReceived;

                <tr>
                    <td>@invoice.InvoiceNumber</td>
                    <td>@invoice.InvoiceDate.ToString("dd-MM-yyyy")</td>
                    <td>@invoice.Customer?.Name</td>
                    <td>@invoice.NetAmount.ToString("N2")</td>
                    <td>@invoice.AdvanceReceived.ToString("N2")</td>
                    <td>@orderBalance.ToString("N2")</td>
                    <td>
                        <span class="badge bg-@statusBadgeColor">@statusText</span>
                    </td>
                    <td class="text-end">
                        @if (invoice.Status == 0) // Draft status
                        {
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Edit", "Invoices", new { id = invoice.Id })">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger delete-invoice-btn" data-invoice-id="@invoice.Id" data-invoice-number="@invoice.InvoiceNumber" title="Delete this draft invoice">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Preview", "Invoices", new { id = invoice.Id })">
                                <i class="fas fa-edit me-1"></i>View
                            </a>
                            <a class="btn btn-sm btn-outline-success" target="_blank" href="@Url.Action("Print", "Invoices", new { id = invoice.Id, invoiceNumber = invoice.InvoiceNumber })">
                                <i class="fas fa-print me-1"></i>Print
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-info add-payment-btn" data-invoice-id="@invoice.Id" data-invoice-number="@invoice.InvoiceNumber" data-net-amount="@invoice.NetAmount" data-advance-received="@invoice.AdvanceReceived" data-our-order-reference="@invoice.OurOrderReference" data-bs-toggle="modal" data-bs-target="#paymentModal">
                                <i class="fas fa-credit-card me-1"></i>Add Payment
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-4">No invoices found matching your criteria.</td>
            </tr>
        }
    </tbody>
</table>

<!-- Compact Payment Modal with Two-Column Layout -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentModalLabel">
                    <i class="fas fa-credit-card me-2"></i>Add Payment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Invoice Information Row -->
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">Invoice #</label>
                        <input type="text" class="form-control form-control-sm" id="paymentInvoiceNumber" readonly />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Remaining</label>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" id="paymentRemainingAmount" readonly />
                            <button class="btn btn-outline-secondary btn-sm" type="button" id="fillRemainingBtn" title="Fill remaining amount">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Payment Details Row -->
                <div class="row mb-3">
                    <div class="col-6">
                        <label for="paymentAmount" class="form-label">Amount *</label>
                        <input type="number" class="form-control form-control-sm" id="paymentAmount" placeholder="0.00" step="0.01" min="0" required />
                    </div>
                    <div class="col-6">
                        <label for="paymentDate" class="form-label">Date *</label>
                        <input type="date" class="form-control form-control-sm" id="paymentDate" required />
                    </div>
                </div>

                <!-- Payment Mode Row -->
                <div class="row mb-3">
                    <div class="col-6">
                        <label for="paymentMode" class="form-label">Payment Mode *</label>
                        <select class="form-select form-select-sm" id="paymentMode" required>
                            <option value="0">Cash</option>
                            <option value="1">Cheque</option>
                            <option value="2" selected>Online</option>
                        </select>
                    </div>
                    <div class="col-6" id="referenceFieldContainer">
                        <label class="form-label" id="referenceLabel">Transaction Ref</label>
                        <input type="text" class="form-control form-control-sm" id="referenceField" maxlength="100">
                    </div>
                </div>

                <input type="hidden" id="paymentInvoiceId" />
                <input type="hidden" id="paymentNetAmount" />
                <input type="hidden" id="paymentAdvanceReceived" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="addPaymentBtn">
                    <i class="fas fa-save me-1"></i>Add Payment
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalCount > Model.PageSize)
{
    <nav aria-label="Invoices pagination">
        <ul class="pagination justify-content-center">
            @{
                var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                var startPage = Math.Max(1, Model.Page - 2);
                var endPage = Math.Min(totalPages, Model.Page + 2);

                var routeValues = new Dictionary<string, string?>();
                if (!string.IsNullOrEmpty(currentInvoiceNumber)) routeValues["invoiceNumber"] = currentInvoiceNumber;
                if (!string.IsNullOrEmpty(currentFrom)) routeValues["from"] = currentFrom;
                if (!string.IsNullOrEmpty(currentTo)) routeValues["to"] = currentTo;
                if (!string.IsNullOrEmpty(currentStatus)) routeValues["status"] = currentStatus;
                if (!string.IsNullOrEmpty(currentCustomerId)) routeValues["CustomerId"] = currentCustomerId;
            }

            <!-- Previous Button -->
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                @if (Model.Page > 1)
                {
                    routeValues["page"] = (Model.Page - 1).ToString();
                    <a class="page-link" href="@Url.Action("Index", routeValues)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>

            <!-- First Page -->
            @if (startPage > 1)
            {
                routeValues["page"] = "1";
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            <!-- Page Numbers -->
            @for (int i = startPage; i <= endPage; i++)
            {
                routeValues["page"] = i.ToString();
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">@i</a>
                </li>
            }

            <!-- Last Page -->
            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                routeValues["page"] = totalPages.ToString();
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">@totalPages</a>
                </li>
            }

            <!-- Next Button -->
            <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                @if (Model.Page < totalPages)
                {
                    routeValues["page"] = (Model.Page + 1).ToString();
                    <a class="page-link" href="@Url.Action("Index", routeValues)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            // Set payment date to today by default
            const today = new Date().toISOString().split('T')[0];
            $('#paymentDate').val(today);

            // Handle payment mode change to show/hide appropriate fields
            $('#paymentMode').change(function () {
                const selectedMode = $(this).val();
                const referenceLabel = $('#referenceLabel');
                const referenceField = $('#referenceField');
                const referenceContainer = $('#referenceFieldContainer');

                // Clear the input value
                referenceField.val('');

                // Update label and visibility based on selection
                if (selectedMode === '0') { // Cash
                    referenceContainer.hide();
                } else if (selectedMode === '1') { // Cheque
                    referenceLabel.text('Cheque Number');
                    referenceField.attr('placeholder', 'Enter cheque number');
                    referenceContainer.show();
                } else if (selectedMode === '2') { // Online
                    referenceLabel.text('Transaction Ref');
                    referenceField.attr('placeholder', 'Enter transaction reference');
                    referenceContainer.show();
                }
            });

            // Initialize payment mode display
            $('#paymentMode').trigger('change');

            // Handle Add Payment button click - populate modal with invoice data
            $(document).on('click', '.add-payment-btn', function () {
                const invoiceId = $(this).data('invoice-id');
                const invoiceNumber = $(this).data('invoice-number');
                const netAmount = $(this).data('net-amount');
                const advanceReceived = $(this).data('advance-received');
                selectedOrderReference = $(this).data('our-order-reference');

                // Populate modal fields
                $('#paymentInvoiceId').val(invoiceId);
                $('#paymentInvoiceNumber').val(invoiceNumber);
                $('#paymentNetAmount').val(parseFloat(netAmount).toFixed(2));
                $('#paymentAdvanceReceived').val(parseFloat(advanceReceived).toFixed(2));
                $('#paymentAmount').val('');

                // Calculate remaining amount
                const remainingAmount = netAmount - advanceReceived;
                $('#paymentRemainingAmount').val(remainingAmount > 0 ? remainingAmount.toFixed(2) : '0.00');

                // Reset payment mode to Online and trigger change
                $('#paymentMode').val('2').trigger('change');

                // Focus on amount field
                setTimeout(() => $('#paymentAmount').focus(), 500);
            });

            // Handle Fill Remaining button click
            $('#fillRemainingBtn').click(function () {
                const remainingAmount = $('#paymentRemainingAmount').val();
                $('#paymentAmount').val(remainingAmount);
            });

            // Handle Add Payment button click in modal
            $('#addPaymentBtn').click(function () {
                const invoiceId = $('#paymentInvoiceId').val();
                const amount = $('#paymentAmount').val();
                const paymentDate = $('#paymentDate').val();
                const paymentMode = $('#paymentMode').val();
                const referenceValue = $('#referenceField').val();

                // Validation
                if (!amount || parseFloat(amount) <= 0) {
                    alert('Please enter a valid payment amount');
                    $('#paymentAmount').focus();
                    return;
                }

                if (!paymentDate) {
                    alert('Please select a payment date');
                    $('#paymentDate').focus();
                    return;
                }

                // Validate reference if payment mode requires it
                if ((paymentMode === '1' || paymentMode === '2') && !referenceValue.trim()) {
                    const fieldName = paymentMode === '1' ? 'cheque number' : 'transaction reference';
                    alert(`Please enter a ${fieldName}`);
                    $('#referenceField').focus();
                    return;
                }

                // Call AddPayment action
                addPayment(invoiceId, parseFloat(amount), paymentDate, selectedOrderReference, paymentMode, referenceValue);
            });

            // Handle Delete button click
            $(document).on('click', '.delete-invoice-btn', function () {
                const invoiceId = $(this).data('invoice-id');
                const invoiceNumber = $(this).data('invoice-number');

                if (confirm(`Are you sure you want to delete the draft invoice "${invoiceNumber}"? This action cannot be undone.`)) {
                    deleteInvoice(invoiceId);
                }
            });

            function addPayment(invoiceId, amount, paymentDate, orderReference, paymentMode, referenceValue) {
                const paymentData = {
                    id: parseInt(invoiceId),
                    amount: amount,
                    paymentDate: paymentDate,
                    ourOrderReference: orderReference,
                    paymentMode: parseInt(paymentMode)
                };

                // Add appropriate reference field based on payment mode
                if (paymentMode === '1') {
                    paymentData.chequeNumber = referenceValue;
                } else if (paymentMode === '2') {
                    paymentData.transactionReference = referenceValue;
                }

                // Disable button to prevent double submission
                $('#addPaymentBtn').prop('disabled', true).text('Adding...');

                $.ajax({
                    type: 'POST',
                    url: '/Invoices/AddPayment',
                    contentType: 'application/json',
                    data: JSON.stringify(paymentData),
                    success: function (response) {
                        if (response.success) {
                            // Close modal
                            const modalElement = document.getElementById('paymentModal');
                            const modal = bootstrap.Modal.getInstance(modalElement);
                            if (modal) {
                                modal.hide();
                            }

                            // Show success message
                            alert(response.message || 'Payment added successfully');

                            // Reload page to reflect changes
                            location.reload();
                        } else {
                            alert('Error: ' + (response.message || 'Failed to add payment'));
                            $('#addPaymentBtn').prop('disabled', false).html('<i class="fas fa-save me-1"></i>Add Payment');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error:', error);
                        alert('Error adding payment: ' + error);
                        $('#addPaymentBtn').prop('disabled', false).html('<i class="fas fa-save me-1"></i>Add Payment');
                    }
                });
            }

            function deleteInvoice(invoiceId) {
                $.ajax({
                    type: 'POST',
                    url: '/Invoices/Delete/' + invoiceId,
                    contentType: 'application/json',
                    success: function (response) {
                        if (response.success) {
                            alert(response.message || 'Invoice deleted successfully');
                            location.reload();
                        } else {
                            alert('Error: ' + (response.message || 'Failed to delete invoice'));
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error:', error);
                        alert('Error deleting invoice: ' + error);
                    }
                });
            }
        });
    </script>
}