@using BillingSuite.Application.DTOs
@using BillingSuite.Domain.Enums
@model BillingSuite.Application.Results.PagedResult<OrderDto>
@{
    Layout = "_Layout";
    var currentPage = ViewContext.HttpContext.Request.Query["page"].ToString();
    var currentFrom = ViewContext.HttpContext.Request.Query["from"].ToString();
    var currentTo = ViewContext.HttpContext.Request.Query["to"].ToString();
    var currentCustomerId = ViewContext.HttpContext.Request.Query["CustomerId"].ToString();
    var currentOrderNumber = ViewContext.HttpContext.Request.Query["orderNumber"].ToString();
    var currentStatus = ViewContext.HttpContext.Request.Query["status"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Orders</h3>
    <a class="btn btn-primary" href="/Orders/Create">Create</a>
</div>

<!-- Filters Section -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Filters</h5>
    </div>
    <div class="card-body">
        <form method="get" action="/Orders" class="row g-3">
            <div class="col-md-2">
                <label for="orderNumber" class="form-label">Order Number</label>
                <input type="text" class="form-control" id="orderNumber" name="orderNumber" value="@currentOrderNumber" />
            </div>
            <div class="col-md-2">
                <label for="from" class="form-label">From Date</label>
                <input type="date" class="form-control" id="from" name="from" value="@currentFrom" />
            </div>
            <div class="col-md-2">
                <label for="to" class="form-label">To Date</label>
                <input type="date" class="form-control" id="to" name="to" value="@currentTo" />
            </div>
            <div class="col-md-2">
                <label for="status" class="form-label">Status</label>
                <select class="form-select" id="status" name="status">
                    <option value="">All Status</option>
                    <option value="0" selected="@(currentStatus == "0")">Draft</option>
                    <option value="1" selected="@(currentStatus == "1")">Confirmed</option>
                    <option value="2" selected="@(currentStatus == "2")">Cancelled</option>
                    <option value="3" selected="@(currentStatus == "3")">Completed</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="CustomerId" class="form-label">Customer</label>
                <select class="form-select" id="CustomerId" name="CustomerId">
                    <option value="">All Customers</option>
                    @if (ViewBag.Customers != null)
                    {
                        @foreach (var customer in (IEnumerable<CustomerDto>)ViewBag.Customers)
                        {
                            <option value="@customer.Id" selected="@(currentCustomerId == customer.Id.ToString())">@customer.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                <a href="/Orders" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Results Summary -->
@if (Model.TotalCount > 0)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
            Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount orders
        </small>
    </div>
}

<!-- Orders Table -->
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Order #</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Net Amount</th>
            <th>Advance Received</th>
            <th>Order Balance</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var order in Model.Items)
            {
                var statusBadgeColor = order.Status switch
                {
                    0 => "secondary",  // Draft
                    1 => "info",       // Confirmed
                    2 => "danger",     // Cancelled
                    3 => "success",    // Completed
                    _ => "dark"
                };
                var statusText = ((OrderStatus)order.Status).ToString();
                var orderBalance = order.NetAmount - order.AdvanceReceived;

                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.OrderDate.ToString("dd-MM-yyyy")</td>
                    <td>@order.Customer?.Name</td>
                    <td>@order.NetAmount.ToString("N2")</td>
                    <td>@order.AdvanceReceived.ToString("N2")</td>
                    <td>@orderBalance.ToString("N2")</td>
                    <td>
                        <span class="badge bg-@statusBadgeColor">@statusText</span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-info" href="@Url.Action("Preview", "Orders", new { id = order.Id })">
                            <i class="fas fa-eye me-1"></i>View
                        </a>
                        @if (order.Status == 0) // Draft status
                        {
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Edit", "Orders", new { id = order.Id })">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger delete-order-btn" data-order-id="@order.Id" data-order-number="@order.OrderNumber" title="Delete this draft order">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-warning update-status-btn" data-order-id="@order.Id" data-order-number="@order.OrderNumber" data-current-status="@order.Status" data-bs-toggle="modal" data-bs-target="#statusModal">
                                <i class="fas fa-sync me-1"></i>Update Status
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-4">No orders found matching your criteria.</td>
            </tr>
        }
    </tbody>
</table>

<!-- Status Update Modal -->
<div class="modal fade" id="statusModal" tabindex="-1" aria-labelledby="statusModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statusModalLabel">Update Order Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="orderNumberDisplay" class="form-label">Order Number:</label>
                    <input type="text" class="form-control" id="orderNumberDisplay" readonly />
                </div>
                <div class="mb-3">
                    <label for="statusSelect" class="form-label">New Status:</label>
                    <select class="form-select" id="statusSelect">
                        <option value="">-- Select Status --</option>
                        <option value="0">Draft</option>
                        <option value="1">Confirmed</option>
                        <option value="2">Cancelled</option>
                        <option value="3">Completed</option>
                    </select>
                </div>
                <input type="hidden" id="orderIdInput" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="updateStatusBtn">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalCount > Model.PageSize)
{
    <nav aria-label="Orders pagination">
        <ul class="pagination justify-content-center">
            @{
                var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                var startPage = Math.Max(1, Model.Page - 2);
                var endPage = Math.Min(totalPages, Model.Page + 2);

                var routeValues = new Dictionary<string, string?>();
                if (!string.IsNullOrEmpty(currentOrderNumber)) routeValues["orderNumber"] = currentOrderNumber;
                if (!string.IsNullOrEmpty(currentFrom)) routeValues["from"] = currentFrom;
                if (!string.IsNullOrEmpty(currentTo)) routeValues["to"] = currentTo;
                if (!string.IsNullOrEmpty(currentStatus)) routeValues["status"] = currentStatus;
                if (!string.IsNullOrEmpty(currentCustomerId)) routeValues["CustomerId"] = currentCustomerId;
            }

            <!-- Previous Button -->
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                @if (Model.Page > 1)
                {
                    routeValues["page"] = (Model.Page - 1).ToString();
                    <a class="page-link" href="@Url.Action("Index", routeValues)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>

            <!-- First Page -->
            @if (startPage > 1)
            {
                routeValues["page"] = "1";
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            <!-- Page Numbers -->
            @for (int i = startPage; i <= endPage; i++)
            {
                routeValues["page"] = i.ToString();
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">@i</a>
                </li>
            }

            <!-- Last Page -->
            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                routeValues["page"] = totalPages.ToString();
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", routeValues)">@totalPages</a>
                </li>
            }

            <!-- Next Button -->
            <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                @if (Model.Page < totalPages)
                {
                    routeValues["page"] = (Model.Page + 1).ToString();
                    <a class="page-link" href="@Url.Action("Index", routeValues)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            // Handle Update Status button click - populate modal with order data
            $(document).on('click', '.update-status-btn', function () {
                const orderId = $(this).data('order-id');
                const orderNumber = $(this).data('order-number');
                const currentStatus = $(this).data('current-status');

                // Populate modal fields
                $('#orderIdInput').val(orderId);
                $('#orderNumberDisplay').val(orderNumber);
                $('#statusSelect').val(currentStatus);
            });

            // Handle OK button click in modal
            $('#updateStatusBtn').click(function () {
                const orderId = $('#orderIdInput').val();
                const newStatus = $('#statusSelect').val();

                if (!newStatus || newStatus === '') {
                    alert('Please select a status');
                    return;
                }

                // Call UpdateStatus action
                updateOrderStatus(orderId, newStatus);
            });

            // Handle Delete button click
            $(document).on('click', '.delete-order-btn', function () {
                const orderId = $(this).data('order-id');
                const orderNumber = $(this).data('order-number');

                if (confirm(`Are you sure you want to delete the draft order "${orderNumber}"? This action cannot be undone.`)) {
                    deleteOrder(orderId);
                }
            });

            function updateOrderStatus(orderId, newStatus) {
                $.ajax({
                    type: 'POST',
                    url: '/Orders/UpdateStatus',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        id: parseInt(orderId),
                        orderStatus: parseInt(newStatus)
                    }),
                    success: function (response) {
                        if (response.success) {
                            // Close modal
                            const modalElement = document.getElementById('statusModal');
                            const modal = bootstrap.Modal.getInstance(modalElement);
                            if (modal) {
                                modal.hide();
                            }

                            // Show success message
                            alert(response.message || 'Order status updated successfully');

                            // Reload page to reflect changes
                            location.reload();
                        } else {
                            alert('Error: ' + (response.message || 'Failed to update status'));
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error:', error);
                        alert('Error updating status: ' + error);
                    }
                });
            }

            function deleteOrder(orderId) {
                $.ajax({
                    type: 'POST',
                    url: '/Orders/Delete/' + orderId,
                    contentType: 'application/json',
                    success: function (response) {
                        if (response.success) {
                            alert(response.message || 'Order deleted successfully');
                            location.reload();
                        } else {
                            alert('Error: ' + (response.message || 'Failed to delete order'));
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error:', error);
                        alert('Error deleting order: ' + error);
                    }
                });
            }
        });
    </script>
}