@model BillingSuite.Web.Models.SettingsViewModel

@{
    ViewData["Title"] = "Settings";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1 class="h2 text-primary mb-0">
                        <i class="fas fa-cog me-2"></i>Settings
                    </h1>
                    <p class="text-muted mb-0">Manage your company and tax configuration</p>
                </div>
                <div class="badge bg-light text-dark px-3 py-2">
                    <i class="fas fa-calendar me-1"></i>
                    Last updated: @DateTime.Now.ToString("MMM dd, yyyy")
                </div>
            </div>
        </div>
    </div>

    <!-- Success Message -->
    @if (TempData["msg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["msg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Settings Tabs Navigation -->
    <div class="row mb-4">
        <div class="col-12">
            <ul class="nav nav-pills nav-fill bg-light rounded p-1" id="settingsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="company-tab" data-bs-toggle="pill" data-bs-target="#company" type="button" role="tab">
                        <i class="fas fa-building me-2"></i>Company Settings
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tax-tab" data-bs-toggle="pill" data-bs-target="#tax" type="button" role="tab">
                        <i class="fas fa-percentage me-2"></i>Tax Settings
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content" id="settingsTabContent">

        <!-- Company Settings Tab -->
        <div class="tab-pane fade show active" id="company" role="tabpanel">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-building me-2"></i>Company Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Index" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="CompanySettings.Id" />

                        <div class="row g-4">
                            <!-- Company Name -->
                            <div class="col-md-6">
                                <label asp-for="CompanySettings.CompanyName" class="form-label fw-semibold">
                                    <i class="fas fa-building text-primary me-1"></i>Company Name *
                                </label>
                                <input asp-for="CompanySettings.CompanyName" class="form-control form-control-lg"
                                       placeholder="Enter your company name" />
                                <span asp-validation-for="CompanySettings.CompanyName" class="text-danger small"></span>
                            </div>

                            <!-- GSTIN -->
                            <div class="col-md-6">
                                <label asp-for="CompanySettings.Gstin" class="form-label fw-semibold">
                                    <i class="fas fa-file-invoice text-primary me-1"></i>GSTIN
                                </label>
                                <input asp-for="CompanySettings.Gstin" class="form-control"
                                       placeholder="Enter GSTIN number" />
                            </div>

                            <!-- Address -->
                            <div class="col-md-8">
                                <label asp-for="CompanySettings.Address" class="form-label fw-semibold">
                                    <i class="fas fa-map-marker-alt text-primary me-1"></i>Company Address
                                </label>
                                <textarea asp-for="CompanySettings.Address" class="form-control" rows="3"
                                          placeholder="Enter your complete business address"></textarea>
                            </div>

                            <!-- Phone -->
                            <div class="col-md-4">
                                <label asp-for="CompanySettings.Phone" class="form-label fw-semibold">
                                    <i class="fas fa-phone text-primary me-1"></i>Phone Number
                                </label>
                                <input asp-for="CompanySettings.Phone" class="form-control" type="tel"
                                       placeholder="Enter phone number" />
                            </div>

                            <!-- Logo Upload -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    <i class="fas fa-image text-primary me-1"></i>Company Logo
                                </label>
                                <div class="input-group">
                                    <input type="file" name="logo" class="form-control" accept="image/*" />
                                    <span class="input-group-text">
                                        <i class="fas fa-upload"></i>
                                    </span>
                                </div>
                                <div class="form-text">Supported formats: JPG, PNG, GIF (Max: 2MB)</div>
                            </div>

                            <!-- Terms and Conditions -->
                            <div class="col-12">
                                <label asp-for="CompanySettings.TermsAndConditions" class="form-label fw-semibold">
                                    <i class="fas fa-file-contract text-primary me-1"></i>Terms & Conditions
                                </label>
                                <textarea asp-for="CompanySettings.TermsAndConditions" class="form-control" rows="6"
                                          placeholder="Enter your terms and conditions..."></textarea>
                                <div class="form-text">These terms will appear on all invoices and documents.</div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg px-4">
                                    <i class="fas fa-save me-2"></i>Save Company Settings
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tax Settings Tab -->
        <div class="tab-pane fade" id="tax" role="tabpanel">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-percentage me-2"></i>Tax Configuration
                    </h5>
                    <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#addTaxModal">
                        <i class="fas fa-plus me-1"></i>Add New Tax
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (Model.TaxSettings.Items.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="px-4 py-3">
                                            <i class="fas fa-tag me-1"></i>Tax Type
                                        </th>
                                        <th class="px-4 py-3">
                                            <i class="fas fa-percentage me-1"></i>Tax Rate (%)
                                        </th>
                                        <th class="px-4 py-3 text-end">
                                            <i class="fas fa-cog me-1"></i>Actions
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tax in Model.TaxSettings.Items)
                                    {
                                        <tr class="tax-row">
                                            <td class="px-4 py-3 align-middle">
                                                <div class="d-flex align-items-center">
                                                    <div class="tax-type-badge bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 12px; font-weight: bold;">
                                                        @tax.TaxType.Substring(0, Math.Min(2, tax.TaxType.Length)).ToUpper()
                                                    </div>
                                                    <span class="fw-semibold">@tax.TaxType</span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-3 align-middle">
                                                <span class="badge bg-info fs-6">@tax.TaxPercent.ToString("F2")%</span>
                                            </td>
                                            <td class="px-4 py-3 align-middle text-end">
                                                <div class="btn-group" role="group">
                                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                                            onclick="editTax(@tax.Id, '@tax.TaxType', @tax.TaxPercent)"
                                                            data-bs-toggle="modal" data-bs-target="#editTaxModal"
                                                            title="Edit Tax Setting">
                                                        <i class="fas fa-edit me-1"></i>Edit
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                                            onclick="confirmDelete(@tax.Id, '@tax.TaxType')"
                                                            title="Delete Tax Setting">
                                                        <i class="fas fa-trash me-1"></i>Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-percentage text-muted" style="font-size: 4rem;"></i>
                            <h5 class="text-muted mt-3">No Tax Settings Configured</h5>
                            <p class="text-muted">Add your first tax setting to get started.</p>
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaxModal">
                                <i class="fas fa-plus me-1"></i>Add Tax Setting
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Tax Modal -->
<div class="modal fade" id="addTaxModal" tabindex="-1" aria-labelledby="addTaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="addTaxModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Add New Tax Setting
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddTaxSetting" method="post">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="NewTaxSetting.TaxType" class="form-label fw-semibold">
                                <i class="fas fa-tag me-1"></i>Tax Type
                            </label>
                            <input asp-for="NewTaxSetting.TaxType" class="form-control"
                                   placeholder="e.g., GST, VAT, CGST" required />
                        </div>
                        <div class="col-12">
                            <label asp-for="NewTaxSetting.TaxPercent" class="form-label fw-semibold">
                                <i class="fas fa-percentage me-1"></i>Tax Rate (%)
                            </label>
                            <input asp-for="NewTaxSetting.TaxPercent" class="form-control" type="number"
                                   step="0.01" placeholder="e.g., 18.00" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-plus me-1"></i>Add Tax Setting
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Tax Modal -->
<div class="modal fade" id="editTaxModal" tabindex="-1" aria-labelledby="editTaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editTaxModalLabel">
                    <i class="fas fa-edit me-2"></i>Edit Tax Setting
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateTaxSetting" method="post" id="editTaxForm">
                <div class="modal-body">
                    <input type="hidden" id="editTaxId" name="Id" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-tag me-1"></i>Tax Type
                            </label>
                            <input type="text" class="form-control" id="editTaxType" name="TaxType" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-percentage me-1"></i>Tax Rate (%)
                            </label>
                            <input type="number" class="form-control" id="editTaxPercent" name="TaxPercent" step="0.01" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Update Tax Setting
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteTaxModal" tabindex="-1" aria-labelledby="deleteTaxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteTaxModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Are you sure you want to delete this tax setting?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Tax Type:</strong> <span id="deleteTaxName"></span><br>
                    <small>This action cannot be undone. Any invoices using this tax setting may be affected.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <form asp-action="DeleteTaxSetting" method="post" class="d-inline" id="deleteTaxForm">
                    <input type="hidden" id="deleteTaxId" name="id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Delete Tax Setting
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .card:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
            }

        .nav-pills .nav-link {
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .nav-pills .nav-link.active {
                background: linear-gradient(135deg, #0d6efd, #0b5ed7);
                box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
            }

        .form-control {
            border-radius: 8px;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
            }

        .btn {
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .btn:hover {
                transform: translateY(-1px);
            }

        .tax-row:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }

        .tax-type-badge {
            font-family: 'Segoe UI', sans-serif;
        }

        .table th {
            border-top: none;
            font-weight: 600;
            color: #495057;
        }

        .alert {
            border-radius: 12px;
            border: none;
        }

        .badge {
            border-radius: 6px;
        }

        .form-text {
            font-size: 0.875rem;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            border: none;
        }

        .modal-content {
            border-radius: 12px;
            border: none;
        }

        .modal-header {
            border-radius: 12px 12px 0 0 !important;
        }

        .btn-close-white {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function editTax(id, taxType, taxPercent) {
            document.getElementById('editTaxId').value = id;
            document.getElementById('editTaxType').value = taxType;
            document.getElementById('editTaxPercent').value = taxPercent;
        }

        function confirmDelete(id, taxType) {
            document.getElementById('deleteTaxId').value = id;
            document.getElementById('deleteTaxName').textContent = taxType;

            const deleteModal = new bootstrap.Modal(document.getElementById('deleteTaxModal'));
            deleteModal.show();
        }

        // Clear form when add modal is closed
        document.getElementById('addTaxModal').addEventListener('hidden.bs.modal', function () {
            document.querySelector('#addTaxModal input[name="NewTaxSetting.TaxType"]').value = '';
            document.querySelector('#addTaxModal input[name="NewTaxSetting.TaxPercent"]').value = '';
        });

        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                if (alert.querySelector('.btn-close')) {
                    alert.querySelector('.btn-close').click();
                }
            });
        }, 5000);
    </script>
}